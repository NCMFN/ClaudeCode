# Ignore data files
data/raw/*
data/processed/*
*.csv
*.tsv
*.biom
*.zip
*.tar.gz
*.pcap

# Ignore models
models/*.pt
models/*.pth
models/*.h5
models/*.pkl

# Ignore environments
venv/
.env
__pycache__/
*.pyc

# Allow keeping directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!models/.gitkeep
!results/.gitkeep
